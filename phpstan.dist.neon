parameters:
    level: 8
    paths:
        - bin/
        - config/
        - public/
        - src/
        - tests/
    excludePaths:
        analyse:
            - config/object-manager.php
            - tests/bootstrap.php
    doctrine:
        objectManagerLoader: config/object-manager.php
includes:
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-doctrine/rules.neon
